# Test Environment Configuration

# Database Configuration (Main)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=securevault
DB_SSLMODE=disable

# Database Configuration (Test)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres
TEST_DB_NAME=securevault_test
TEST_DB_SSLMODE=disable

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server Configuration
PORT=8080
ENVIRONMENT=development  # Set to "production" to disable GraphQL playground/introspection

# CORS Configuration (optional)
CORS_ALLOWED_ORIGIN=*  # Set to specific origin in production (e.g., https://yourdomain.com)

# Rate Limiting
RATE_LIMIT_RPS=2

# Storage Configuration
QUOTA_BYTES=10485760
STORAGE_PATH=./storage

# S3 Configuration (optional)
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=