# GraphQL Schema for SecureVault
# Mirrors REST API endpoints with snake_case field names to match existing JSON responses

# Custom scalars
scalar UUID
scalar DateTime

# Enums
enum UserRole {
  user
  admin
}

# Types matching existing models and REST responses
type User {
  id: UUID!
  email: String!
  role: UserRole!
  rate_limit_rps: Int!
  storage_quota_bytes: Int!
  created_at: DateTime!
}

type File {
  id: UUID!
  owner_id: UUID!
  original_filename: String!
  mime_type: String!
  size_bytes: Int!
  folder_id: UUID
  is_public: Boolean!
  download_count: Int!
  tags: [String!]!
  created_at: DateTime!
  updated_at: DateTime!
  deleted_at: DateTime
  share_link: ShareLink
}

type Folder {
  id: UUID!
  owner_id: UUID!
  name: String!
  parent_id: UUID
  created_at: DateTime!
  updated_at: DateTime!
  deleted_at: DateTime
  share_link: ShareLink
}

type ShareLink {
  id: UUID!
  token: String!
  is_active: Boolean!
  download_count: Int!
  created_at: DateTime!
}

# Auth payload for login/signup
type AuthPayload {
  token: String!
  user: User!
}

# Statistics types matching REST API exactly
type StatsResponse {
  total_files: Int!
  total_size_bytes: Int!
  quota_bytes: Int!
  quota_used_bytes: Int!
  quota_available_bytes: Int!
  files_by_type: [FileTypeEntry!]!
  upload_history: [UploadHistoryEntry!]!
}

type FileTypeEntry {
  mime_type: String!
  count: Int!
}

type UploadHistoryEntry {
  date: String!
  count: Int!
  total_size: Int!
}

type AdminStatsResponse {
  total_users: Int!
  total_files: Int!
  total_size_bytes: Int!
  total_quota_bytes: Int!
  quota_utilization_percent: Float!
  files_by_type: [FileTypeEntry!]!
  users_by_registration_date: [RegistrationEntry!]!
  storage_by_user: [UserStorageEntry!]!
  most_active_users: [ActiveUserEntry!]!
}

type RegistrationEntry {
  date: String!
  count: Int!
}

type UserStorageEntry {
  user_id: UUID!
  user_email: String!
  file_count: Int!
  total_size_bytes: Int!
  quota_bytes: Int!
}

type ActiveUserEntry {
  user_id: UUID!
  user_email: String!
  file_count: Int!
  last_upload: DateTime
  total_downloads: Int!
}

# Trash response for listing trashed items
type TrashResponse {
  files: [File!]!
  folders: [Folder!]!
  page: Int!
  page_size: Int!
  total: Int!
}

# List responses matching REST structure exactly
type FileListResponse {
  files: [File!]!
  page: Int!
  page_size: Int!
  total: Int!
}

# Folder response types matching REST API
type FolderDetailsResponse {
  folder: Folder!
  breadcrumbs: [Folder!]!
}

type FolderChildrenResponse {
  folders: [Folder!]!
  files: [File!]!
  pagination: FolderPaginationInfo!
}

type FolderPaginationInfo {
  page: Int!
  page_size: Int!
  total_folders: Int!
  total_files: Int!
  has_more: Boolean!
}

type AdminFilesResponse {
  files: [AdminFileEntry!]!
  pagination: PaginationInfo!
}

type AdminFileEntry {
  id: UUID!
  filename: String!
  size: Int!
  mime_type: String!
  upload_date: DateTime!
  user_email: String!
  user_id: UUID!
  is_public: Boolean!
  download_count: Int!
}

type PaginationInfo {
  page: Int!
  page_size: Int!
  total: Int!
  total_pages: Int!
}

# Root Query type
type Query {
  # Simple test query
  hello: String!

  # Current user info (mirrors /api/v1/stats/me user portion)
  me: User!

  # List current user's files with filters (mirrors GET /api/v1/files)
  files(
    filename: String
    mime_type: String
    folder_id: UUID # filter by folder ID - UUID or null for root level
    tags: String # comma-separated
    page: Int = 1
    page_size: Int = 20
  ): FileListResponse!

  # Folder queries (mirrors REST folder endpoints)
  # List folder contents (mirrors GET /api/v1/folders)
  folders(parent_id: UUID): FolderChildrenResponse!

  # Simple query to get only folders (no files) - avoids complex SQL
  foldersOnly(parent_id: UUID): [Folder!]!

  # Get all folders owned by the current user (flat list for client-side tree building)
  allFolders: [Folder!]!

  # Get folder details with breadcrumbs (mirrors GET /api/v1/folders/{id})
  folder(id: UUID!): FolderDetailsResponse!

  # Get file details by ID (owner only) (mirrors GET /api/v1/files/{id})
  file(id: UUID!): File!

  # Current user's statistics (mirrors /api/v1/stats/me exactly)
  stats(
    from: String # Start date for upload history (YYYY-MM-DD)
    to: String # End date for upload history (YYYY-MM-DD)
    group_by: String # Grouping for upload history (day, week, month, year)
  ): StatsResponse!

  # Public file metadata by token (no auth required) (mirrors public download metadata)
  publicFile(token: String!): File!

  # Public folder access by token (no auth required) (mirrors GET /api/v1/p/f/{token})
  # Returns the contents of the shared folder (files and subfolders), but not the main folder info
  publicFolder(
    token: String!
    page: Int = 1
    page_size: Int = 20
  ): FolderChildrenResponse!

  # Trash / Recycle Bin query
  trash(page: Int, page_size: Int): TrashResponse!

  # Admin-only queries
  # List all files with admin details (mirrors GET /api/v1/admin/files)
  adminFiles(
    user_id: UUID
    user_email: String
    filename: String
    mime_type: String
    tags: String
    page: Int = 1
    page_size: Int = 20
  ): AdminFilesResponse!

  # Global admin statistics (mirrors GET /api/v1/admin/stats)
  adminStats: AdminStatsResponse!

  # --- AI Tag queries ---
  # Get all unique tags for the current user (for Tag Explorer)
  allTags: [FileTagInfo!]!

  # Get the most popular tags for the current user
  popularTags(limit: Int = 10): [FileTagInfo!]!

  # Get search autocomplete suggestions (matching tags and files)
  searchSuggestions(query: String!, limit: Int = 10): [SearchSuggestion!]!

  # Get AI tag generation job status for a file
  aiTags(file_id: UUID!): AiTagJob

  # Get AI description for a file (cached or generate)
  aiDescription(file_id: UUID!): AiDescriptionResult!

  # Get full AI analysis for a file (tags + description + folder)
  aiAnalysis(file_id: UUID!): AiAnalysisResult!
}

# Root Mutation type
type Mutation {
  # Authentication mutations (mirror REST auth endpoints)
  signup(email: String!, password: String!): AuthPayload!
  login(email: String!, password: String!): AuthPayload!

  # File management mutations
  # Toggle file public visibility (mirrors PATCH /api/v1/files/{id}/public)
  toggleFilePublic(id: UUID!, is_public: Boolean!): File!

  # Delete file (mirrors DELETE /api/v1/files/{id})
  deleteFile(id: UUID!): Boolean!

  # Move file to folder (mirrors PATCH /api/v1/files/{id}/move)
  moveFile(file_id: UUID!, folder_id: UUID): File!

  # Folder mutations (mirrors REST folder endpoints)
  # Create folder (mirrors POST /api/v1/folders)
  createFolder(name: String!, parent_id: UUID): Folder!

  # Update/rename folder (mirrors PATCH /api/v1/folders/{id})
  updateFolder(id: UUID!, name: String): Folder!

  # Move folder (mirrors PATCH /api/v1/folders/{id} with parent_id)
  moveFolder(id: UUID!, parent_id: UUID): Folder!

  # Delete folder (mirrors DELETE /api/v1/folders/{id})
  deleteFolder(id: UUID!, recursive: Boolean = true): Boolean!

  # Folder sharing mutations (mirror REST folder sharing endpoints)
  # Create folder share link (mirrors POST /api/v1/folders/{id}/share)
  createFolderShareLink(id: UUID!): ShareLink!

  # Delete folder share link (mirrors DELETE /api/v1/folders/{id}/share)
  deleteFolderShareLink(id: UUID!): Boolean!

  # Trash / Recycle Bin mutations
  trashFile(id: UUID!): Boolean!
  trashFolder(id: UUID!, recursive: Boolean = true): Boolean!
  restoreFile(id: UUID!): File!
  restoreFolder(id: UUID!): Folder!
  permanentDeleteFile(id: UUID!): Boolean!
  permanentDeleteFolder(id: UUID!): Boolean!
  emptyTrash: Boolean!

  # --- AI Tag mutations ---
  # Replace all tags on a file (source of truth: file_tags table)
  updateFileTags(file_id: UUID!, tags: [String!]!): File!

  # Manually trigger AI tag generation for a file
  generateAiTags(file_id: UUID!): AiTagJob!

  # Generate AI description for a file (synchronous, cached)
  generateAiDescription(file_id: UUID!): AiDescriptionResult!

  # Bulk trigger AI tagging for multiple files
  bulkGenerateAiTags(file_ids: [UUID!]!): BulkAiTagResult!

  # Admin-only mutations
  # Admin delete file (mirrors DELETE /api/v1/admin/files/{id})
  adminDeleteFile(id: UUID!): Boolean!
}

# --- AI Tags types ---

# A tag with metadata from the file_tags table
type FileTagInfo {
  name: String!
  is_ai_generated: Boolean!
  confidence: Float!
  count: Int!
}

# Status of an AI tag generation job (V2: includes description + folder)
type AiTagJob {
  id: UUID!
  file_id: UUID!
  status: String!
  suggested_tags: [String!]!
  confidence_scores: [Float!]!
  ai_description: String!
  suggested_folder: String
  error_message: String
  created_at: DateTime!
  completed_at: DateTime
}

# Result from AI description generation
type AiDescriptionResult {
  file_id: UUID!
  description: String!
  status: String!
}

# Result from bulk AI tag generation
type BulkAiTagResult {
  queued_count: Int!
  skipped_count: Int!
  status: String!
  message: String!
}

# Full AI analysis result (tags + description + folder)
type AiAnalysisResult {
  file_id: UUID!
  suggested_tags: [String!]!
  confidence_scores: [Float!]!
  description: String!
  suggested_folder: String
  status: String!
}

# Search suggestion (tag or file match)
type SearchSuggestion {
  type: String!
  value: String!
  id: String!
  count: Int!
}

# Note: File upload and download remain REST-only as specified
# Clients should use:
# - POST /api/v1/files for uploads (multipart/form-data)
# - GET /api/v1/files/{id}/download for downloads
# - GET /p/{token} for public downloads
